<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="xq.yiesko.app180go.fragments.splash.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/home_navigation" />
    </fragment>

    <navigation
        android:id="@+id/home_navigation"
        app:startDestination="@id/homeFragment">

        <fragment
            android:id="@+id/homeFragment"
            android:name="xq.yiesko.app180go.fragments.home.HomeFragment"
            android:label="Home">
            <action
                android:id="@+id/action_home_to_calc"
                app:destination="@id/calcFragment" />
            <action
                android:id="@+id/action_home_to_about"
                app:destination="@id/aboutFragment" />
        </fragment>

        <fragment
            android:id="@+id/calcFragment"
            android:name="xq.yiesko.app180go.fragments.home.pages.calc.CalcFragment"
            android:label="Calculator"
            tools:layout="@layout/fragment_calc" />

        <fragment
            android:id="@+id/aboutFragment"
            android:name="xq.yiesko.app180go.fragments.home.pages.about.AboutFragment"
            android:label="About"
            tools:layout="@layout/fragment_about" />
    </navigation>
</navigation>